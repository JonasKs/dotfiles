export ZSH="$HOME/.oh-my-zsh"
# Theme
ZSH_THEME="robbyrussell"

# Set ulimit to a higher number (instead of default 2048) so our tmux sessions
# don't get killed because of missing fd's..
ulimit -n 1048576

# Plugins
plugins=(
    git
    man
    kubectl
    zsh-syntax-highlighting
    zsh-autosuggestions
    zsh-completions
)

source $ZSH/oh-my-zsh.sh

# Aliases
if [ -f ~/.aliasesrc ]; then
    . ~/.aliasesrc
fi
eval "$(starship init zsh)"

# fzf
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
export FZF_DEFAULT_OPTS='--height=40%'

# Rust
export CARGO_TARGET_DIR=/Users/jonas/.cargo-target

# Go
export PATH="$HOME/go/bin:$PATH"

# Completions
autoload -Uz compinit
zstyle ':completion:*' menu select
fpath+=~/.zfunc
fpath=(/Users/jonas/.docker/completions $fpath)
compinit

export CLAUDE_CODE_USE_FOUNDRY=0

# Secrets (not tracked by chezmoi)
[ -f ~/.secrets ] && source ~/.secrets
