name=Jonas Krüger Svensson

[core]
editor = "nvim"

[alias]
lol=log --oneline --decorate --graph --all
uncommit=reset HEAD~1 --soft
undelete="!f() { git reset -q -- "$@" && git checkout -- "$@"; }; f"

[pull]
rebase = false

[user]
  signingkey = ssh-rsa 

[gpg]
  format = ssh

[gpg "ssh"]
  program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"

[commit]
  gpgsign = true
